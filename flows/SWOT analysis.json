        "jsCode": "const allSignals = [];\n\nfor (const item of $input.all()) {\n  const signals = item.json.signals || [];\n  allSignals.push(...signals);\n}\n\nreturn [{\n  json: {\n    signals: allSignals\n  }\n}];"
