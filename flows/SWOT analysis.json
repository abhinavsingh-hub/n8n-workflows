      "parameters": {
        "jsCode": "let raw = $input.first().json.text || \"\";\n\n// Extract JSON\nconst match = raw.match(/\\{[\\s\\S]*\\}/);\n\nif (!match) {\n  return [{\n    json: {\n      error: \"No JSON found in reflection output\",\n      raw_output: raw\n    }\n  }];\n}\n\nlet parsed;\n\ntry {\n  parsed = JSON.parse(match[0]);\n} catch (err) {\n  return [{\n    json: {\n      error: \"Reflection JSON parsing failed\",\n      raw_output: match[0]\n    }\n  }];\n}\n\n// Structured result\nreturn [{\n  json: {\n    improvement_needed: parsed.improvement_needed ?? false,\n    feedback: parsed.feedback || \"\",\n    final_decision: parsed.final_decision || \"\"\n  }\n}];"
      },
