      "parameters": {
        "jsCode": "let raw = $input.first().json.text || \"\";\n\nconst strengths = [];\nconst weaknesses = [];\nconst opportunities = [];\nconst threats = [];\n\nlet currentSection = null;\n\n// split lines\nconst lines = raw.split(\"\\n\");\n\nfor (let line of lines) {\n  line = line.trim();\n\n  if (/strength/i.test(line)) {\n    currentSection = \"strengths\";\n    continue;\n  }\n\n  if (/weakness/i.test(line)) {\n    currentSection = \"weaknesses\";\n    continue;\n  }\n\n  if (/opportunit/i.test(line)) {\n    currentSection = \"opportunities\";\n    continue;\n  }\n\n  if (/threat/i.test(line)) {\n    currentSection = \"threats\";\n    continue;\n  }\n\n  // extract numbered points\n  if (/^\\d+\\./.test(line)) {\n    const cleaned = line\n      .replace(/^\\d+\\.\\s*/, \"\")\n      .replace(/\\*\\*/g, \"\")\n      .split(\":\")[0]\n      .trim();\n\n    if (currentSection === \"strengths\") strengths.push(cleaned);\n    if (currentSection === \"weaknesses\") weaknesses.push(cleaned);\n    if (currentSection === \"opportunities\") opportunities.push(cleaned);\n    if (currentSection === \"threats\") threats.push(cleaned);\n  }\n}\n\nreturn [{\n  json: {\n    strengths,\n    weaknesses,\n    opportunities,\n    threats\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1088,
        288
      ],
      "id": "e73f66a6-5268-4c83-ba9d-0f71e00bb8dc",
      "name": "Code in JavaScript1"
    },
    {
      "parameters": {
        "jsCode": "const text = $json.text || \"\";\n\n// bigger chunks = fewer LLM calls\nconst chunkSize = 5000;\nconst overlap = 300;\n\nconst chunks = [];\n\nfor (let i = 0; i < text.length; i += chunkSize - overlap) {\n  chunks.push({\n    chunk: text.slice(i, i + chunkSize)\n  });\n}\n\nreturn chunks.map(c => ({ json: c }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        528,
        -64
      ],
      "id": "f32b3aa6-4443-420f-88b6-f3994985d31c",
      "name": "Code in JavaScript2"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a financial analyst.\n\nFrom the provided financial report text extr\n{{ $json.chunk }}\nFocus on:\n- Revenue trends\n- Profit margins\n- Debt levels\n- Cash flow\n- Market risks\n- Growth opportunities\n- Key financial metrics\n\nReturn structured JSON:\n\n{\n \"company_summary\":\"\",\n \"financial_health\":\"\",\n \"key_metrics\":[]\n} ",
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
