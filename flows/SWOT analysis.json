    {
      "parameters": {
        "jsCode": "let raw = $input.first().json.text || \"\";\n\n// Extract JSON block\nconst match = raw.match(/\\{[\\s\\S]*\\}/);\n\nif (!match) {\n  return [{\n    json: {\n      error: \"No JSON found in investment output\",\n      raw_output: raw\n    }\n  }];\n}\n\nlet parsed;\n\ntry {\n  parsed = JSON.parse(match[0]);\n} catch (err) {\n  return [{\n    json: {\n      error: \"Investment JSON parsing failed\",\n      raw_output: match[0]\n    }\n  }];\n}\n\n// Return clean structured output\nreturn [{\n  json: {\n    investment_decision: parsed.investment_decision || \"\",\n    confidence: parsed.confidence || 0,\n    reasoning: parsed.reasoning || \"\"\n  }\n}];"
      },
