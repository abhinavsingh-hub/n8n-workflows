      ],
      "id": "59b951fd-8fbf-4bb4-b3bd-6f0cf84573bc",
      "name": "financial signals agent"
    },
    {
      "parameters": {
        "jsCode": "let raw = $input.first().json.text || \"\";\n\nconst match = raw.match(/\\{[\\s\\S]*\\}/);\n\nif (!match) {\n  return [{ json: { signals: [] } }];\n}\n\nreturn [{\n  json: JSON.parse(match[0])\n}];"
      },
